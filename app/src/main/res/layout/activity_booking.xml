<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvMovieTitleHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/design_default_color_primary"
        android:padding="16dp"
        android:text="Tên Phim"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/containerInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Thông tin rạp/suất sẽ được code Java chèn vào đây -->

            <Spinner
                android:id="@+id/spShowtimes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvUnitPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giá vé: $0.0"
                android:textSize="16sp"
                android:textColor="@color/design_default_color_primary"
                android:layout_marginBottom="16dp"
                android:textStyle="bold"
                android:visibility="gone"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHỌN GHẾ (Hàng A-H, Cột 1-7)"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"
                android:textColor="#757575"/>

            <GridLayout
                android:id="@+id/glSeats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:columnCount="7"
                android:layout_marginBottom="24dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvSelectedSeats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ghế chọn: Chưa có"
                android:layout_marginBottom="24dp"
                android:textSize="18sp"/>

            <Button
                android:id="@+id/btnBookTicket"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="ĐẶT VÉ NGAY"
                android:textAllCaps="true"
                android:backgroundTint="@color/design_default_color_primary"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:elevation="4dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>